{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint src",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "gen:api": "openapi-typescript ../typespec/tsp-output/openapi.yaml -o src/api/schema.d.ts",
    "mock": "prism mock ../typespec/tsp-output/openapi.yaml --dynamic",
    "dev:mock": "concurrently \"npm run mock\" \"npm run dev\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@mantine/core": "^9.4.0",
    "@mantine/dates": "^9.4.0",
    "@mantine/form": "^9.4.0",
    "@mantine/hooks": "^9.4.0",
    "@mantine/notifications": "^9.4.0",
    "@tanstack/react-query": "^5.101.1",
    "dayjs": "^1.11.21",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.14.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
